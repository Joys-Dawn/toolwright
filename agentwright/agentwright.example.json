{
  "pipelines": {
    "default": ["implementation", "correctness", "best-practices", "behavior", "test-coverage"],
    "full": [
      "implementation",
      "correctness",
      "security",
      "best-practices",
      ["migration", "ui"],
      "behavior",
      "test-coverage"
    ]
  },
  "customStages": {
    "perf": {
      "type": "skill",
      "skillId": "performance-investigation"
    },
    "audit-bundle": {
      "type": "skill",
      "skillIds": ["correctness-audit", "security-audit", "best-practices-audit"]
    }
  },
  "retention": {
    "keepCompletedRuns": 2,
    "deleteCompletedLogs": true,
    "deleteCompletedFindings": false,
    "maxRunAgeDays": 2
  }
}
